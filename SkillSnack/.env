## Frontend environment template for SkillSnack (Expo)
## Copy this file to ".env" (or ".env.development") and adjust values as needed.
##
## Expo only exposes variables to the app if they start with EXPO_PUBLIC_.

# Base URL for the SkillSnack backend API.
# For local development with the Express server running on your machine:
# - Web (Expo): usually "http://localhost:4000"
# - Physical device: use your machine's LAN IP instead of localhost, e.g. "http://192.168.1.10:4000"
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

