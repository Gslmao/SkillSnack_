SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: where your frontend is hosted, for CORS.
# Use "*" for any origin during local development.
CORS_ORIGIN=http://localhost:3000

# API base URL – used by both frontend (SkillSnack) and backend.
# Backend derives its port from this (e.g. http://localhost:4000 → port 4000).
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Optional: override port (used if EXPO_PUBLIC_API_BASE_URL is unset or has no port)
# PORT=4000

